# Personal Assistant environment template.
# Keep real secrets in .env or the relevant provider vault, never in committed docs.

# Optional alternate config path for experiments.
PERSONAL_ASSISTANT_CONFIG=

# Enable verbose DEBUG/TRACE logging for local tools.
PERSONAL_ASSISTANT_DEBUG_LOGS=0

# Optional token for the local mobile webhook bridge.
PERSONAL_ASSISTANT_MOBILE_BRIDGE_TOKEN=

# Future direct OpenAI/OpenClaw route for gpt-5.5.
OPENAI_API_KEY=

# Optional future archive target. Leave empty until S3 archive is explicitly enabled.
PA_ARCHIVE_S3_BUCKET=
PA_ARCHIVE_S3_PREFIX=
